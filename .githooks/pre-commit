#!/bin/sh
# Pre-commit hook: formatting, linting, and tests must pass before a commit.
# Enable locally once with:  git config core.hooksPath .githooks

set -e

echo "==> cargo oneway (fmt --check + clippy + oneway-lints)"
if [ -d "../oneway-lints/lints" ]; then
    export ONEWAY_LINTS_PATH="$(cd ../oneway-lints/lints && pwd)"
    echo "    (using local oneway-lints from $ONEWAY_LINTS_PATH)"
fi
cargo oneway

# NOTE: cargo-oneway's `sorted_derives` rule covers what cargo-sort-derives
# used to enforce; running both side-by-side disagrees on ordering for
# qualified derives (e.g. `schemars::JsonSchema`).
echo "==> cargo machete"
cargo machete --with-metadata

echo "==> cargo test"
cargo test --all --locked
